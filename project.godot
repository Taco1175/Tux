; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but changes done here will be saved in the same format.

config_version=5

[application]

config/name="TUX"
config/description="Four penguin siblings descend into the corrupted deep to rescue their parents — and uncover the sin that started it all."
run/main_scene="res://scenes/main_menu/MainMenu.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://assets/sprites/ui/icon.png"

[autoload]

GameManager="*res://scripts/globals/GameManager.gd"
NetworkManager="*res://scripts/globals/NetworkManager.gd"
ItemDatabase="*res://scripts/globals/ItemDatabase.gd"
UnlockManager="*res://scripts/globals/UnlockManager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/initial_screen=0
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

